{
  "name": "@signal-kit/cli",
  "version": "0.1.0",
  "description": "CLI event stream for Signal Kit Twitch EventSub relay tokens.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "signal-kit": "dist/index.js",
    "signalkit": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "twitch",
    "eventsub",
    "websocket",
    "cli",
    "signal-kit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R44VC0RP/signal-kit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://signal.ryan.ceo",
  "dependencies": {
    "@signal-kit/client": "^0.1.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.6",
    "typescript": "^5"
  }
}
